{
  "name": "mimo-provider",
  "displayName": "MiMo by Xiaomi",
  "description": "Use Xiaomi MiMo V2 models as a full coding agent in Antigravity and VS Code — chat panel, tool calling, file editing, terminal execution, and smart context management.",
  "version": "0.9.6",
  "publisher": "drdelco",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/drdelco/mimo-provider"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "mimo",
    "xiaomi",
    "ai",
    "language-model",
    "chat",
    "antigravity",
    "llm",
    "coding-assistant"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "icons": {
      "mimo-logo": {
        "description": "MiMo logo icon",
        "default": {
          "fontPath": "./icon-font/mimo-icons.woff",
          "fontCharacter": "\\f101"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mimo-sidebar",
          "title": "MiMo by Xiaomi",
          "icon": "activity-icon.png"
        }
      ]
    },
    "views": {
      "mimo-sidebar": [
        {
          "type": "webview",
          "id": "mimo.chatView",
          "name": "MiMo Chat"
        }
      ]
    },
    "languageModelChatProviders": [
      {
        "vendor": "mimo",
        "displayName": "Xiaomi MiMo",
        "managementCommand": "mimo.manage"
      }
    ],
    "chatParticipants": [
      {
        "id": "mimo",
        "name": "MiMo",
        "description": "Xiaomi MiMo AI coding assistant",
        "isSticky": true
      }
    ],
    "commands": [
      {
        "command": "mimo.manage",
        "title": "MiMo: Configure API Key"
      },
      {
        "command": "mimo.test",
        "title": "MiMo: Test Connection"
      },
      {
        "command": "mimo.openChat",
        "title": "MiMo: Open Chat Panel",
        "icon": "$(mimo-logo)"
      },
      {
        "command": "mimo.newChat",
        "title": "MiMo: New Chat"
      },
      {
        "command": "mimo.clearHistory",
        "title": "MiMo: Clear Chat History"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "mimo.openChat",
          "group": "navigation",
          "when": "true"
        }
      ]
    },
    "configuration": {
      "title": "MiMo Provider",
      "properties": {
        "mimo.apiKey": {
          "type": "string",
          "default": "",
          "description": "MiMo API Key"
        },
        "mimo.baseUrl": {
          "type": "string",
          "default": "https://token-plan-ams.xiaomimimo.com/v1",
          "description": "MiMo API base URL"
        },
        "mimo.useFlashForSimpleTasks": {
          "type": "boolean",
          "default": false,
          "description": "Use MiMo V2 Flash for simple tool calls (read, search, list). Only enable if your plan includes Flash."
        },
        "mimo.webSearch": {
          "type": "boolean",
          "default": true,
          "description": "Use Xiaomi's native Web Search plugin (requires it to be enabled at platform.xiaomimimo.com > Plugin Management). When disabled, uses free DuckDuckGo-based local search as fallback."
        },
        "mimo.preferredModel": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "mimo-v2-pro",
            "mimo-v2-flash"
          ],
          "description": "Preferred model. Auto selects Pro for complex tasks and Flash for simple tool calls."
        },
        "mimo.deepseekApiKey": {
          "type": "string",
          "default": "",
          "description": "DeepSeek API Key (get one at platform.deepseek.com)"
        },
        "mimo.deepseekBaseUrl": {
          "type": "string",
          "default": "https://api.deepseek.com",
          "description": "DeepSeek API base URL"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.0"
  }
}
